{
  "name": "@ricokahler/mcp-cli",
  "version": "0.1.2",
  "description": "A JSON-first MCP client CLI for bash-capable agents.",
  "type": "module",
  "license": "MIT",
  "author": "Rico Kahler",
  "homepage": "https://github.com/ricokahler/mcp-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ricokahler/mcp-cli.git"
  },
  "bugs": {
    "url": "https://github.com/ricokahler/mcp-cli/issues"
  },
  "bin": {
    "mcp-cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "config.schema.json",
    "README.md",
    "LICENSE"
  ],
  "os": [
    "darwin"
  ],
  "cpu": [
    "arm64",
    "x64"
  ],
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.9.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node scripts/clean.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "pack:check": "pnpm build && publint && node scripts/check-pack.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm pack:check",
    "prepack": "pnpm clean && pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@napi-rs/keyring": "1.3.0",
    "commander": "15.0.0",
    "jsonc-parser": "3.3.1",
    "smol-toml": "1.7.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "publint": "0.3.21",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vitest": "4.1.10"
  }
}
